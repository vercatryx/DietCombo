# Unite Us credentials — Regular account (no quotes)
UNITEUS_EMAIL=your-email@example.com
UNITEUS_PASSWORD=your-password

# Unite Us credentials — Brooklyn account (used when dropdown is set to Brooklyn)
UNITEUS_EMAIL_BROOKLYN=your-brooklyn-email@example.com
UNITEUS_PASSWORD_BROOKLYN=your-brooklyn-password

# Number of browser slots for parallel runs (editable in the dashboard; saved here)
CONCURRENT_BROWSERS=10

# Run Chromium headless (true/false) — dashboard toggle writes this value
HEADLESS=true

# When HEADLESS=false and CONCURRENT_BROWSERS>1, tile each Chromium window on screen (2×2 for 4, 4×2 for 8, …).
# TILE_WINDOWS=false turns this off. TILE_SCREEN_* should match your display (logical pixels on Retina).
TILE_WINDOWS=true
TILE_SCREEN_WIDTH=1920
TILE_SCREEN_HEIGHT=1080
TILE_GUTTER=6
TILE_ORIGIN_X=0
TILE_ORIGIN_Y=0

# Headed tiles: emulate full-screen desktop layout for CSS/media (TILE_LAYOUT_* / TILE_SCREEN_*) via Chrome DevTools; tile OS window stays put. Set false to disable.
TILE_CDP_FULL_LAYOUT=true

# Virtual desktop size for emulation above (defaults = TILE_SCREEN_*).
TILE_LAYOUT_VIEWPORT_WIDTH=
TILE_LAYOUT_VIEWPORT_HEIGHT=

# Scale the full emulated page to fit inside each tile (whole “desktop” visible, shrunk — default on).
TILE_SHRINK_FULL_LAYOUT_TO_TILE=true
# Estimated browser chrome height (tabs/toolbar) subtracted from tile height when fitting; raise if clipped, lower if extra margin.
TILE_CHROME_UI_HEIGHT=88

# Must match EXTENSION_API_KEY on the Next.js app (e.g. .env.local or Vercel).
# Used for /api/extension/update-client-authorization and billing-requests.
EXTENSION_API_KEY=your-api-key
EXTENSION_API_BASE_URL=http://customer.thedietfantasy.com

# Automation browser: stub navigator.geolocation so Chromium never shows the location permission dialog (default).
# BILLING_ALLOW_GEOLOCATION=true

# --- Demo / screen recording (company demo build) ---
# Queue + logs: cap rows and replace client names with "Demo client N"; strip loose PII fields from API payloads.
DEMO_SAFE_QUEUE=true
DEMO_QUEUE_LIMIT=20
# Where to persist the downloaded queue so restarts skip re-fetching /api/bill (default: demo_queue_cache.json next to server).
# BILLING_QUEUE_CACHE_PATH=
# Max rows in that file (default: same as DEMO_QUEUE_LIMIT).
# BILLING_QUEUE_CACHE_LIMIT=20
# After opening a client URL: read PHI from the contact column, replace matching text site-wide with dummy values.
# If unset while DEMO_SAFE_QUEUE=true, anonymization is still ON (inherit). Set to false to disable.
DEMO_ANONYMIZE_PATIENT_UI=true
# Comma-separated elapsed times (ms from first pass) for repeated DOM passes while React hydrates (many fast ticks by default).
# DEMO_ANONYMIZE_SETTLE_MS=0,40,85,...
# Same idea after the billing shelf closes / form updates.
# DEMO_ANONYMIZE_POST_MS=0,35,80,...
# Mutation guard: debounce before calling host (ms) / min gap between host runs (ms).
# DEMO_ANONYMIZE_GUARD_DEBOUNCE_MS=60
# DEMO_ANONYMIZE_GUARD_THROTTLE_MS=180
# Max wait (ms) for contact column before anonymize sweep (short = more aggressive; failures ignored).
# DEMO_ANONYMIZE_WAIT_MS=700
# When unset: ON if DEMO_SAFE_QUEUE=true — MutationObserver re-runs anonymize after SPA DOM updates (set false to disable).
# DEMO_ANONYMIZE_DOM_GUARD=true
# Ms to wait after page.goto before the first anonymize sweep (demo only; default 320).
# DEMO_NAV_SETTLE_MS=320
# Do not click the final billing "Post" / submit button (no record submitted to Unite Us).
DEMO_SKIP_BILLING_SUBMIT=true
# After a demo run (submit skipped), stay on the client page this many milliseconds before the next client (default 6000).
DEMO_PAUSE_MS=6000
