+  const code = err && (err.code || (err.cause && err.cause.code));
+  if (code === "ECONNREFUSED" || code === "ETIMEDOUT" || code === "ECONNRESET") {
+    return true;
+  }
   if (!err.response) {
     return false;
   }
   const statusCode = err.response.statusCode;
   const body = err.body;
