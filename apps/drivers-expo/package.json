{
  "name": "drivers-expo",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "start:tunnel": "EXPO_FORCE_WEBCONTAINER_ENV=1 expo start --tunnel",
    "start:tunnel:clean": "npx kill-port 8081 8101 && EXPO_FORCE_WEBCONTAINER_ENV=1 expo start --tunnel",
    "start:lan": "expo start --lan",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "sync-env": "node ./scripts/sync-env-from-root.mjs",
    "use-ngrok": "node ./scripts/use-ngrok-env.mjs",
    "eas-init": "npx eas-cli@latest init",
    "eas-update:production": "CI=1 npx eas-cli@latest update --branch production --platform ios --message \"OTA update\" --non-interactive && CI=1 npx eas-cli@latest update --branch production --platform android --message \"OTA update\" --non-interactive",
    "eas-update:preview": "CI=1 npx eas-cli@latest update --branch preview --platform ios --message \"Preview OTA\" --non-interactive && CI=1 npx eas-cli@latest update --branch preview --platform android --message \"Preview OTA\" --non-interactive"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "patch-package": "^8.0.1",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
