# Copy to .env or run: npm run sync-env (pulls NEXT_PUBLIC_* from repo root as EXPO_PUBLIC_*).
#
# If Expo Go times out loading the bundle, use tunnel mode: npm run start:tunnel (needs: npx expo login)
#
# Local Next.js — default for iOS Simulator / Android emulator / Expo web on the same machine:
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Match dietcombo calendar (optional).
EXPO_PUBLIC_APP_TIMEZONE=America/New_York

# On a physical phone, use ngrok (run `ngrok http 3000`, then `npm run use-ngrok` here), or LAN IP:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:3000
