# Unite Us credentials — Regular account (no quotes)
UNITEUS_EMAIL=your-email@example.com
UNITEUS_PASSWORD=your-password

# Unite Us credentials — Brooklyn account (used when dropdown is set to Brooklyn)
UNITEUS_EMAIL_BROOKLYN=your-brooklyn-email@example.com
UNITEUS_PASSWORD_BROOKLYN=your-brooklyn-password

# Number of browser slots for parallel runs (editable in the dashboard; saved here)
CONCURRENT_BROWSERS=10

# Run Chromium headless (true/false) — dashboard toggle writes this value
HEADLESS=true

# When HEADLESS=false and CONCURRENT_BROWSERS>1, tile each Chromium window on screen (2×2 for 4, 4×2 for 8, …).
# TILE_WINDOWS=false turns this off. TILE_SCREEN_* should match your display (logical pixels on Retina).
TILE_WINDOWS=true
TILE_SCREEN_WIDTH=1920
TILE_SCREEN_HEIGHT=1080
TILE_GUTTER=6
TILE_ORIGIN_X=0
TILE_ORIGIN_Y=0

# Headed tiles: emulate full-screen desktop layout for CSS/media (TILE_LAYOUT_* / TILE_SCREEN_*) via Chrome DevTools; tile OS window stays put. Set false to disable.
TILE_CDP_FULL_LAYOUT=true

# Virtual desktop size for emulation above (defaults = TILE_SCREEN_*).
TILE_LAYOUT_VIEWPORT_WIDTH=
TILE_LAYOUT_VIEWPORT_HEIGHT=

# Scale the full emulated page to fit inside each tile (whole “desktop” visible, shrunk — default on).
TILE_SHRINK_FULL_LAYOUT_TO_TILE=true
# Estimated browser chrome height (tabs/toolbar) subtracted from tile height when fitting; raise if clipped, lower if extra margin.
TILE_CHROME_UI_HEIGHT=88

# Must match EXTENSION_API_KEY on the Next.js app (e.g. .env.local or Vercel).
# Used for /api/extension/update-client-authorization and billing-requests.
EXTENSION_API_KEY=your-api-key
EXTENSION_API_BASE_URL=http://customer.thedietfantasy.com
